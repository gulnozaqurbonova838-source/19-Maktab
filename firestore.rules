rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function callerDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function callerExists() {
      return exists(callerDocPath());
    }

    function callerDoc() {
      return get(callerDocPath());
    }

    function isAdmin() {
      return isSignedIn()
        && callerExists()
        && callerDoc().data.role == 'admin';
    }

    function isValidRole(role) {
      return role == 'user' || role == 'admin';
    }

    // Required on full document create (first sign-up)
    function validUserCreate(userId) {
      let data = request.resource.data;
      return isOwner(userId)
        && data.keys().hasAll(['uid', 'email', 'displayName', 'role'])
        && data.uid == userId
        && data.email is string
        && data.displayName is string
        && data.role == 'user'
        && isValidRole(data.role);
    }

    // Owner may update profile fields but NEVER change role or uid
    function validOwnerUpdate(userId) {
      let data = request.resource.data;
      let existing = resource.data;
      return isOwner(userId)
        && data.uid == existing.uid
        && data.role == existing.role
        && isValidRole(data.role);
    }

    // Admin may update another user (role etc.); uid must not change
    function validAdminUpdate(userId) {
      let data = request.resource.data;
      let existing = resource.data;
      return isAdmin()
        && data.uid == existing.uid
        && data.uid == userId
        && isValidRole(data.role);
    }

    // -------------------------------------------------------------------------
    // users/{userId} — authenticated access only; default deny for all else
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Read own doc OR admin reads any user (list/get)
      allow read: if isOwner(userId) || isAdmin();

      // Create only own document; role forced to "user"
      allow create: if validUserCreate(userId);

      // Owner: safe profile updates | Admin: manage any user
      allow update: if validOwnerUpdate(userId)
        || (isAdmin() && validAdminUpdate(userId));

      // Admin may delete other users (not self)
      allow delete: if isAdmin()
        && request.auth.uid != userId;
    }

    // All other paths: implicitly denied (no match = no access)
  }
}
